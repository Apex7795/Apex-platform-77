# Database
# DATABASE_URL is what the running app/worker connects with. This must be
# the app_user role created by db/migrate_rls_hardening.sql, NOT the
# table-owning role, or tenant RLS silently does nothing (Postgres exempts
# table owners from their own table's RLS policies).
DATABASE_URL=postgres://app_user:changeme@localhost:5432/apex

# MIGRATION_DATABASE_URL is a separate, higher-privilege connection (the
# table-owning role) used only for running db/migrate_*.sql files.
# app_user has no CREATE/ALTER/DROP privileges by design, so migrations
# cannot run over DATABASE_URL once app_user is in place. Never point the
# running app itself at this connection string.
MIGRATION_DATABASE_URL=postgres://postgres:changeme@localhost:5432/apex

# Magic Link / opt-out token signing (shared secret across actionTokens.js
# and prospectOptOutTokens.js)
ACTION_TOKEN_SECRET=replace-with-32-byte-random-hex

# Twilio
# Account SID and Auth Token come from the Twilio Console dashboard homepage.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# WEBHOOK_URL is used to validate Twilio webhook signatures — set it to
# your deployed app's real base URL (e.g. your Render service URL).
WEBHOOK_URL=https://app.example.com
PLATFORM_NOTIFICATION_NUMBER=

# OpenAI
OPENAI_API_KEY=

# Postmark (prospect outreach email)
POSTMARK_SERVER_TOKEN=
OUTREACH_FROM_EMAIL=you@apexjunksolutions.com

# Admin auth gate for /api/prospects/* (server-to-server/script use —
# see lib/adminAuth.js's security note about why this is NOT sufficient
# for the browser dashboard).
ADMIN_API_TOKEN=replace-with-32-byte-random-hex
GOOGLE_PLACES_API_KEY=
HUNTER_API_KEY=
# Comma-separated "City, ST" list used by services/prospectScoring.js's
# geographic fit criterion. Leave unset to skip geographic scoring entirely.
TARGET_SERVICE_AREAS=Sacramento, CA,Stockton, CA,Modesto, CA
# Row in `tenants` that represents Apex's own outreach pipeline, so
# prospect-to-lead conversions don't mix into a paying customer's list.
PROSPECTING_HOUSE_TENANT_ID=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# App
APP_URL=https://app.example.com
PORT=3000
